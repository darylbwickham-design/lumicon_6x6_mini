static inline uint16_t rgb565(uint8_t r, uint8_t g, uint8_t b) {
  return (uint16_t)(((r & 0xF8) << 8) | ((g & 0xFC) << 3) | (b >> 3));
}

static void showCenteredBitmap_P(const uint16_t* bmp, int w, int h, uint16_t bgColor) {
  // IMPORTANT (ESP8266): drawing a full bitmap in one go can starve the watchdog.
  // Draw one row at a time and yield periodically to keep the device stable.
  tft.fillScreen(bgColor);

  int x = (SCREEN_W - w) / 2;
  int y = (SCREEN_H - h) / 2;
  if (x < 0) x = 0;
  if (y < 0) y = 0;

  static uint16_t lineBuf[SCREEN_W]; // max width (160)
  for (int row = 0; row < h; row++) {
    const int base = row * w;
    for (int col = 0; col < w; col++) {
      lineBuf[col] = pgm_read_word(&bmp[base + col]);
    }

    tft.drawRGBBitmap(x, y + row, lineBuf, w, 1);

    // yield every 4 rows to avoid watchdog resets during splash
    if ((row & 3) == 3) yield();
  }
}

static void showRainbowWelcome() {
  tft.fillScreen(BG);
  tft.setTextWrap(false);
  tft.setTextSize(2);

  const char* msg = "WELCOME";
  const int len = (int)strlen(msg);

  const int charW = 6 * 2;
  const int charH = 8 * 2;
  const int x0 = (SCREEN_W - (len * charW)) / 2;
  const int y0 = (SCREEN_H - charH) / 2;

  const uint16_t colors[] = {
    rgb565(255,  64, 118), // pink
    rgb565(255, 128,   0), // orange
    rgb565(255, 255,   0), // yellow
    rgb565(  0, 255, 128), // green
    rgb565(  0, 200, 255), // cyan
    rgb565( 80, 120, 255), // blue
    rgb565(200,  80, 255), // purple
  };
  const int colorCount = (int)(sizeof(colors) / sizeof(colors[0]));

  for (int i = 0; i < len; i++) {
    tft.setTextColor(colors[i % colorCount], BG);
    tft.setCursor(x0 + i * charW, y0);
    tft.print(msg[i]);
  }

  // Restore defaults used by the rest of the firmware
  tft.setTextSize(1);
  tft.setTextColor(FG, BG);
}

static void runBootSplash() {
  // 1) Lumi-Con logo (1s)
  showCenteredBitmap_P(LOGO_LUMICON_112x112, 112, 112, BG);
  delay(1000);

  // 2) Product title (1s)
  showCenteredBitmap_P(LOGO_6X6_MINI_160x107, 160, 107, BG);
  delay(1000);

  // 3) Rainbow WELCOME (1s)
  showRainbowWelcome();
  delay(1000);

  // Clear before normal boot continues
  tft.fillScreen(BG);
}

