void drawCenteredText(int y, const String& text, uint16_t fg, uint16_t bg) {
  int16_t x1, y1;
  uint16_t w, h;
  tft.getTextBounds(text, 0, y, &x1, &y1, &w, &h);
  int x = (SCREEN_W - (int)w) / 2;
  if (x < 0) x = 0;
  tft.setCursor(x, y);
  tft.setTextColor(fg, bg);
  tft.print(text);
}

void waitSplash(uint32_t ms) {
  uint32_t start = millis();
  while (elapsedMs(millis(), start) < ms) {
    yield();
  }
}


static void drawCenteredBitmap_P(const uint16_t* bmp, int w, int h, uint16_t bgColor) {
  tft.fillScreen(bgColor);

  int x = (SCREEN_W - w) / 2;
  int y = (SCREEN_H - h) / 2;
  if (x < 0) x = 0;
  if (y < 0) y = 0;

  static uint16_t lineBuf[SCREEN_W];
  for (int row = 0; row < h; ++row) {
    const int base = row * w;
    for (int col = 0; col < w; ++col) {
      lineBuf[col] = pgm_read_word(&bmp[base + col]);
    }
    tft.drawRGBBitmap(x, y + row, lineBuf, w, 1);
    if ((row & 3) == 3) yield();
  }
}

