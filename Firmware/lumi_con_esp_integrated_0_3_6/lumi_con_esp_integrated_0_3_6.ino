uint32_t lastWifiAttemptMs = 0;

void ensureWiFi(uint32_t now) {
  int st = WiFi.status();
  if (st == WL_CONNECTED) return;
  if (elapsedMs(now, lastWifiAttemptMs) < WIFI_RETRY_MS) return;
  lastWifiAttemptMs = now;
  WiFi.reconnect();
}

