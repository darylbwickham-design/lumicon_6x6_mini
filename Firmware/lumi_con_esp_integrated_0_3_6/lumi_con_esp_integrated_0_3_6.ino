void appendTextPageMessage(const String& msgRaw) {
  String clean = msgRaw;
  clean.replace("\r", " ");
  clean.replace("\n", " ");
  clean.trim();
  if (!clean.length()) return;

  int start = 0;
  while (start < (int)clean.length()) {
    int remaining = (int)clean.length() - start;
    int take = remaining > MAX_COLS ? MAX_COLS : remaining;

    if (remaining > MAX_COLS) {
      int split = -1;
      for (int i = start + take - 1; i > start; --i) {
        if (clean[i] == ' ') {
          split = i;
          break;
        }
      }
      if (split > start) take = split - start;
    }

    String line = clean.substring(start, start + take);
    line.trim();
    if (!line.length()) {
      start += take + 1;
      continue;
    }

    if (textPageLineCount < TEXT_PAGE_HISTORY_LINES) {
      textPageLines[textPageLineCount++] = line;
    } else {
      for (uint8_t i = 1; i < TEXT_PAGE_HISTORY_LINES; ++i) {
        textPageLines[i - 1] = textPageLines[i];
      }
      textPageLines[TEXT_PAGE_HISTORY_LINES - 1] = line;
    }

    start += take;
    while (start < (int)clean.length() && clean[start] == ' ') start++;
  }
}

void addNoPetWelcomeLines() {
  textPageHasPlaceholder = true;
  if (uiMode == UI_MODE_CHAT) {
    appendTextPageMessage("Chat mode");
    appendTextPageMessage("Lumia messages only");
    appendTextPageMessage("Waiting for events...");
  } else if (uiMode == UI_MODE_NOPET_DEBUG) {
    appendTextPageMessage("noPet Debug");
    appendTextPageMessage("Lumia + key debug");
    appendTextPageMessage("Waiting for events...");
  }
}


void buildWrappedLines(const String& msgRaw, String* outLines, uint8_t& outCount) {
  outCount = 0;
  String clean = msgRaw;
  clean.replace("\r", " ");
  clean.replace("\n", " ");
  clean.trim();
  if (!clean.length()) return;

  int start = 0;
  while (start < (int)clean.length() && outCount < TEXT_PAGE_HISTORY_LINES) {
    int remaining = (int)clean.length() - start;
    int take = remaining > MAX_COLS ? MAX_COLS : remaining;

    if (remaining > MAX_COLS) {
      int split = -1;
      for (int i = start + take - 1; i > start; --i) {
        if (clean[i] == ' ') {
          split = i;
          break;
        }
      }
      if (split > start) take = split - start;
    }

    String line = clean.substring(start, start + take);
    line.trim();
    if (line.length()) outLines[outCount++] = line;

    start += take;
    while (start < (int)clean.length() && clean[start] == ' ') start++;
  }
}

void renderNoPetHeader(bool force) {
  uint16_t ackColor = COLOR_WARN;
  String ackText = "ACK: --";
  if (ackState == ACK_OK) {
    ackText = "ACK: OK";
    ackColor = COLOR_GOOD;
  } else if (ackState == ACK_FAIL) {
    ackText = "ACK: FAIL";
    ackColor = COLOR_BAD;
  }

  String ipLine = "IP:";
  if (WiFi.status() == WL_CONNECTED) ipLine += WiFi.localIP().toString();
  else ipLine += "DOWN";

  uint32_t token =
      ((uint32_t)ackState << 16) ^
      (uint32_t)WiFi.localIP() ^
      ((uint32_t)WiFi.status() << 24);

  if (!force && token == lastNoPetHeaderToken) return;
  lastNoPetHeaderToken = token;

  if (force || ackText != lastNoPetAckText || ackColor != lastNoPetAckColor) {
    lastNoPetAckText = ackText;
    lastNoPetAckColor = ackColor;
    drawLineArea(0, ackText, ackColor);
  }

  if (force || ipLine != lastNoPetIpLine) {
    lastNoPetIpLine = ipLine;
    drawLineArea(LINE_H, ipLine, COLOR_FG);
  }

  tft.drawFastHLine(0, 2 * LINE_H, SCREEN_W, COLOR_DIM);
}

void renderNoPetBody(bool force) {
  uint32_t token =
      (uint32_t)textPageLineCount ^
      (textPageUntilMs << 1) ^
      (uint32_t)textPageActive ^
      ((uint32_t)textPageHasPlaceholder << 20);

  for (uint8_t i = 0; i < textPageLineCount && i < TEXT_PAGE_HISTORY_LINES; ++i) {
    token ^= ((uint32_t)textPageLines[i].length() << ((i % 4) * 6));
    if (textPageLines[i].length()) token ^= (uint8_t)textPageLines[i][0] << ((i % 4) * 4);
  }

  if (!force && token == lastNoPetBodyToken) return;
  lastNoPetBodyToken = token;

  const int bodyY = (2 * LINE_H) + 1;
  const int bodyH = SCREEN_H - bodyY;
  tft.fillRect(0, bodyY, SCREEN_W, bodyH, COLOR_BG);

  const uint8_t visibleLines = (SCREEN_H / LINE_H) - 3;
  tft.setTextWrap(false);
  tft.setTextSize(TEXT_SIZE);
  tft.setTextColor(COLOR_FG);
  for (uint8_t i = 0; i < textPageLineCount && i < visibleLines; ++i) {
    tft.setCursor(0, (i + 3) * LINE_H);
    tft.print(textPageLines[i]);
  }
}

void insertTopWrappedMessageNoPet(const String& msgRaw) {
  String wrapped[TEXT_PAGE_HISTORY_LINES];
  uint8_t wrappedCount = 0;
  buildWrappedLines(msgRaw, wrapped, wrappedCount);
  if (!wrappedCount) return;

  if (textPageHasPlaceholder) {
    textPageLineCount = 0;
    textPageHasPlaceholder = false;
  }

  uint8_t oldCount = textPageLineCount;
  uint8_t keepCount = 0;
  if (oldCount < TEXT_PAGE_HISTORY_LINES) keepCount = oldCount;
  else keepCount = TEXT_PAGE_HISTORY_LINES;
  if ((uint8_t)(wrappedCount + keepCount) > TEXT_PAGE_HISTORY_LINES) {
    keepCount = TEXT_PAGE_HISTORY_LINES - wrappedCount;
  }

  for (int i = (int)keepCount - 1; i >= 0; --i) {
    textPageLines[i + wrappedCount] = textPageLines[i];
  }
  for (uint8_t i = 0; i < wrappedCount && i < TEXT_PAGE_HISTORY_LINES; ++i) {
    textPageLines[i] = wrapped[i];
  }

  textPageLineCount = wrappedCount + keepCount;
  if (textPageLineCount > TEXT_PAGE_HISTORY_LINES) textPageLineCount = TEXT_PAGE_HISTORY_LINES;
}

void refreshNoPetPage(bool resetHistory) {
  if (resetHistory) {
    textPageLineCount = 0;
    textPageHasPlaceholder = false;
    addNoPetWelcomeLines();
    lastNoPetHeaderToken = 0;
    lastNoPetBodyToken = 0;
  }

  textPageActive = true;
  textPageUntilMs = 0;
  lastTextPageDrawToken = 0;
  renderNoPetHeader(true);
  renderNoPetBody(true);
}

void renderTextPage(bool force) {
  if (!textPageActive && !force) return;

  if (uiMode == UI_MODE_PET) {
    uint32_t token =
        (uint32_t)textPageLineCount ^
        (textPageUntilMs << 1) ^
        (uint32_t)textPageActive ^
        ((uint32_t)uiMode << 24) ^
        ((uint32_t)ackState << 16) ^
        (uint32_t)WiFi.localIP();

    if (!force && token == lastTextPageDrawToken) return;
    lastTextPageDrawToken = token;

    tft.fillScreen(COLOR_BG);
    tft.setTextWrap(false);
    tft.setTextSize(TEXT_SIZE);
    tft.setTextColor(COLOR_ACCENT, COLOR_BG);
    tft.setCursor(0, 0);
    tft.print("MESSAGES");
    tft.drawFastHLine(0, LINE_H, SCREEN_W, COLOR_DIM);

    tft.setTextColor(COLOR_FG, COLOR_BG);
    for (uint8_t i = 0; i < textPageLineCount && i < TEXT_PAGE_HISTORY_LINES; ++i) {
      tft.setCursor(0, (i + 1) * LINE_H);
      tft.print(textPageLines[i]);
    }
    return;
  }

  renderNoPetHeader(force);
  renderNoPetBody(force);
}

void showTextPage(uint32_t ttlMs) {
  textPageActive = true;
  textPageUntilMs = petModeEnabled() ? (millis() + ttlMs) : 0;

  if (noPetModeActive()) {
    renderNoPetBody(true);
    return;
  }

  renderTextPage(true);
}

void serviceTextPage(uint32_t now) {
  if (noPetModeActive()) {
    if (!textPageActive) {
      refreshNoPetPage(false);
    } else {
      renderTextPage(false);
    }
    return;
  }

  if (!textPageActive) return;
  if ((int32_t)(now - textPageUntilMs) >= 0) {
    textPageActive = false;
    lastTextPageDrawToken = 0;
    renderPetUi(true);
    updateHeaderLine1(true);
    updateHeaderLine2(true);
  }
}

