  tft.fillRect(0, GAME_Y, SCREEN_W, GAME_H, COLOR_BG);
  lastHud0 = lastHud1 = lastHud2 = lastHud3 = "";
  lastFooter = "";
  lastSpriteBaseHash = 255;
  lastSpriteFaceHash = 255;
  lastSpritePoop = 255;
  for (uint8_t i = 0; i < 6; ++i) {
