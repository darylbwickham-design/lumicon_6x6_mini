void drawHudAndBars() {
  String line0 = String(stageName(pet.stage)) + " A:" + String(pet.ageMinutes) + "m";
  if (!pet.alive) line0 += " DOWN";
  else if (pet.sick) line0 += " SICK";
  else if (pet.sleeping) line0 += " SLP";

  String line1;
  switch (statusPage % 4) {
    case 0:
      line1 = "POOP " + String(pet.poop) + " WIFI " + String(WiFi.status() == WL_CONNECTED ? "UP" : "DN");
      break;
    case 1:
      line1 = "HGR " + String(pet.hunger) + " HAP " + String(pet.happiness);
      break;
    case 2:
      line1 = "ENG " + String(pet.energy) + " HYG " + String(pet.hygiene);
      break;
    default:
      line1 = "HLT " + String(pet.health) + " DSP " + String(pet.discipline);
      break;
  }

  drawHudLine(0, line0, lastHud0, COLOR_FG);
  drawHudLine(1, line1, lastHud1, COLOR_DIM);
  drawHudLine(2, "", lastHud2, COLOR_BG);
  drawHudLine(3, "", lastHud3, COLOR_BG);

  const int leftLabelX = 2;
  const int leftBarX = 12;
  const int rightLabelX = 132;
  const int rightBarX = 140;
  const int by = GAME_Y + 18;
  const int bw = 18;

  tft.setTextColor(COLOR_DIM, COLOR_BG);

  tft.setCursor(leftLabelX, by - 1);      tft.print("H");
  tft.setCursor(leftLabelX, by + 10);     tft.print("P");
  tft.setCursor(leftLabelX, by + 20);     tft.print("E");
  tft.setCursor(leftLabelX, by + 30);     tft.print("Y");
  tft.setCursor(rightLabelX, by - 1);     tft.print("L");
  tft.setCursor(rightLabelX, by + 10);    tft.print("D");

  drawBar(leftBarX,  by,      bw, pet.hunger,     moodColor(pet.hunger),     0);
  drawBar(leftBarX,  by + 10, bw, pet.happiness,  moodColor(pet.happiness),  1);
  drawBar(leftBarX,  by + 20, bw, pet.energy,     moodColor(pet.energy),     2);
