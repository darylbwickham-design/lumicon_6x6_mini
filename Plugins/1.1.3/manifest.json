{
  "id": "matrix_6x6_mini",
  "name": "6x6 matrix mini",
  "version": "1.1.3",
  "author": "You",
  "description": "36 key open source stream controller with integrated LCD, chat, alerts, and virtual pet support.",
  "license": "MIT",
  "lumiaVersion": "^9.0.0",
  "category": "devices",
  "icon": "./icon.png",
  "config": {
    "settings_tutorial": "./settings_tutorial.md",
    "actions_tutorial": "./actions_tutorial.md",
    "settings": [
      {
        "key": "enabled",
        "label": "Enable Listener",
        "type": "toggle",
        "defaultValue": true,
        "helperText": "Turns the HTTP listener on/off.",
        "section": "Listener",
        "sectionOrder": 1
      },
      {
        "key": "listenPort",
        "label": "Listen Port",
        "type": "number",
        "defaultValue": 8787,
        "helperText": "ESP will POST events to http://<this-pc-ip>:<port>/event",
        "section": "Listener",
        "sectionOrder": 1
      },
      {
        "key": "secret",
        "label": "Shared Secret (Optional)",
        "type": "password",
        "defaultValue": "",
        "helperText": "If set, ESP must send header X-Matrix-Secret matching this value.",
        "section": "Listener",
        "sectionOrder": 1
      },
      {
        "key": "showAdvanced",
        "label": "Show advanced settings",
        "type": "toggle",
        "defaultValue": false,
        "helperText": "Enable to show timeout/endpoints/UI mode settings.",
        "section": "Listener",
        "sectionOrder": 1
      },
      {
        "key": "debugToasts",
        "label": "Enable debug toasts",
        "type": "toggle",
        "defaultValue": false,
        "helperText": "Shows Lumia toast notifications for device connect/offline (and more if Verbose)."
      },
      {
        "key": "toastVerbosity",
        "label": "Toast verbosity",
        "type": "select",
        "defaultValue": "important",
        "options": [
          { "label": "Important (connect/offline)", "value": "important" },
          { "label": "Verbose (also key/actions/pet)", "value": "verbose" }
        ],
        "helperText": "Verbose can spam if you press many keys.",
        "visibleIf": {
          "key": "debugToasts",
          "equals": true
        }
      },
      {
        "key": "keyLabelsShort",
        "label": "Key labels (Short 0-35)",
        "type": "textarea",
        "defaultValue": "",
        "rows": 12,
        "helperText": "Optional. One label per line, key order 0..35. Used as {{key_label}} for short presses.",
        "section": "Key mapping: Short",
        "sectionOrder": 2
      },
      {
        "key": "keyLabelsLong",
        "label": "Key labels (Long 0-35)",
        "type": "textarea",
        "defaultValue": "",
        "rows": 12,
        "helperText": "Optional. One label per line, key order 0..35. Used as {{key_label}} for long presses.",
        "section": "Key mapping: Long",
        "sectionOrder": 3
      },
      {
        "key": "keyLabels",
        "label": "Legacy key labels (0-35)",
        "type": "textarea",
        "defaultValue": "",
        "rows": 10,
        "helperText": "Legacy single label list (used for both short+long if the new lists are empty).",
        "section": "Advanced",
        "sectionOrder": 4,
        "visibleIf": {
          "key": "showAdvanced",
          "equals": true
        }
      },
      {
        "key": "baseUrl",
        "label": "ESP Base URL (Optional)",
        "type": "url",
        "defaultValue": "",
        "helperText": "Needed for TFT, pet actions, and silent health checks. Example: http://192.168.1.50",
        "section": "Display (optional)",
        "sectionOrder": 3
      },
      {
        "key": "uiMode",
        "label": "ESP UI Mode",
        "type": "select",
        "defaultValue": "legacy_get",
        "options": [
          { "label": "Legacy GET (/msg + /status + /clear)", "value": "legacy_get" },
          { "label": "UI POST (/ui JSON)", "value": "ui_post" }
        ],
        "helperText": "Use legacy_get now. Switch to ui_post later without changing actions.",
        "visibleIf": {
          "key": "showAdvanced",
          "equals": true
        },
        "section": "Advanced",
        "sectionOrder": 4
      },
      {
        "key": "timeoutMs",
        "label": "HTTP Timeout (ms)",
        "type": "number",
        "defaultValue": 2000,
        "helperText": "Timeout waiting for the ESP to respond.",
        "visibleIf": {
          "key": "showAdvanced",
          "equals": true
        },
        "section": "Advanced",
        "sectionOrder": 4
      },
      {
        "key": "msgPath",
        "label": "Message Path",
        "type": "text",
        "defaultValue": "/msg",
        "helperText": "Legacy GET: /msg?t=...",
        "visibleIf": {
          "key": "showAdvanced",
          "equals": true
        },
        "section": "Advanced",
        "sectionOrder": 4
      },
      {
        "key": "statusPath",
        "label": "Status Path",
        "type": "text",
        "defaultValue": "/status",
        "helperText": "Used for silent health checks: /status?silent=1",
        "visibleIf": {
          "key": "showAdvanced",
          "equals": true
        },
        "section": "Advanced",
        "sectionOrder": 4
      },
      {
        "key": "clearPath",
        "label": "Clear Path",
        "type": "text",
        "defaultValue": "/clear",
        "helperText": "Legacy GET: /clear",
        "visibleIf": {
          "key": "showAdvanced",
          "equals": true
        },
        "section": "Advanced",
        "sectionOrder": 4
      },
      {
        "key": "uiPath",
        "label": "UI Path",
        "type": "text",
        "defaultValue": "/ui",
        "helperText": "UI POST endpoint (default /ui).",
        "visibleIf": {
          "key": "showAdvanced",
          "equals": true
        },
        "section": "Advanced",
        "sectionOrder": 4
      },
      {
        "key": "petPath",
        "label": "Pet Path",
        "type": "text",
        "defaultValue": "/pet",
        "helperText": "ESP virtual pet endpoint path (default /pet).",
        "visibleIf": {
          "key": "showAdvanced",
          "equals": true
        },
        "section": "Advanced",
        "sectionOrder": 4
      },
      {
        "key": "offlineTimeoutSec",
        "label": "Offline Timeout (seconds)",
        "type": "number",
        "defaultValue": 30,
        "helperText": "If no events are received for this long, the plugin silently checks the device once before marking it offline.",
        "visibleIf": {
          "key": "showAdvanced",
          "equals": true
        },
        "section": "Advanced",
        "sectionOrder": 4
      }
    ],
    "actions": [
      {
        "type": "display_message",
        "label": "Display: Add Line",
        "description": "Add a line to the device log area.",
        "fields": [
          {
            "key": "message",
            "label": "Message",
            "type": "text",
            "defaultValue": "",
            "allowVariables": true,
            "helperText": "Text to send. Supports Lumia variables/templates."
          }
        ]
      },
      {
        "type": "status_message",
        "label": "Display: Set Status",
        "description": "Set the device status line.",
        "fields": [
          {
            "key": "message",
            "label": "Message",
            "type": "text",
            "defaultValue": "",
            "allowVariables": true,
            "helperText": "Status text. Supports Lumia variables/templates."
          }
        ]
      },
      {
        "type": "clear_screen",
        "label": "Display: Clear",
        "description": "Clear the device display.",
        "fields": []
      },
      {
        "type": "pet_action",
        "label": "Pet Action",
        "description": "Control the virtual pet or request a pet status sync.",
        "fields": [
          {
            "key": "petAction",
            "label": "Pet Action",
            "type": "select",
            "defaultValue": "status",
            "options": [
              { "label": "Status", "value": "status" },
              { "label": "Sync", "value": "sync" },
              { "label": "Feed", "value": "feed" },
              { "label": "Play", "value": "play" },
              { "label": "Clean", "value": "clean" },
              { "label": "Sleep / Toggle Sleep", "value": "sleep" },
              { "label": "Medicine", "value": "med" },
              { "label": "Discipline", "value": "discipline" },
              { "label": "Reset", "value": "reset" }
            ],
            "helperText": "Runs GET /pet?action=... on the ESP firmware."
          }
        ]
      }
    ],
    "variables": [
      { "name": "device_id", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": "", "example": "" },
      { "name": "event", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 0, "example": "0" },
      { "name": "kind", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": "", "example": "" },
      { "name": "received_at", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": "", "example": "" },
      { "name": "key_label", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": "", "example": "" },
      { "name": "device_ip", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": "", "example": "" },
      { "name": "device_rssi", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 0, "example": "0" },
      { "name": "seq", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 0, "example": "0" },
      { "name": "held_ms", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 0, "example": "0" },
      { "name": "device_connected", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": false, "example": "false" },
      { "name": "device_last_seen", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": "", "example": "" },
      { "name": "device_status_text", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": "", "example": "" },
      { "name": "pet_change_name", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": "", "example": "" },
      { "name": "pet_change_code", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 0, "example": "0" },
      { "name": "pet_variation", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 0, "example": "0" },
      { "name": "pet_field_id", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 0, "example": "0" },
      { "name": "pet_field_name", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": "", "example": "" },
      { "name": "pet_from", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 0, "example": "0" },
      { "name": "pet_to", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 0, "example": "0" },
      { "name": "pet_delta", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 0, "example": "0" },
      { "name": "pet_ui_mode", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": "", "example": "" },
      { "name": "pet_mode_enabled", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": false, "example": "false" },
      { "name": "pet_alive", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": false, "example": "false" },
      { "name": "pet_stage", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 0, "example": "0" },
      { "name": "pet_stage_name", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": "", "example": "" },
      { "name": "pet_age_minutes", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 0, "example": "0" },
      { "name": "pet_hunger", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 0, "example": "0" },
      { "name": "pet_happiness", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 0, "example": "0" },
      { "name": "pet_energy", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 0, "example": "0" },
      { "name": "pet_hygiene", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 0, "example": "0" },
      { "name": "pet_health", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 0, "example": "0" },
      { "name": "pet_discipline", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 0, "example": "0" },
      { "name": "pet_poop", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 0, "example": "0" },
      { "name": "pet_sick", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": false, "example": "false" },
      { "name": "pet_sleeping", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": false, "example": "false" },
      { "name": "pet_event_base", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 72, "example": "72" },
      { "name": "pet_event_count", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 22, "example": "22" },
      { "name": "pet_queue_depth", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": 0, "example": "0" },
      { "name": "pet_last_change_code", "system": true, "origin": "device", "allowedPlaces": ["chat", "overlay", "alert"], "value": -1, "example": "-1" }
    ],
    "alerts": [
      {
        "title": "6x6 short",
        "key": "matrix_6x6_short",
        "acceptedVariables": [
